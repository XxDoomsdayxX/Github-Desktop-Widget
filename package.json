{
  "name": "gitpulse",
  "productName": "GitPulse",
  "version": "1.0.0",
  "description": "Floating desktop widget for monitoring GitHub repository sync status.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "generate-icon": "node scripts/generate-icon.js",
    "build": "npm run generate-icon && electron-builder --win",
    "dist": "npm run build"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.gitpulse.widget",
    "productName": "GitPulse",
    "copyright": "Copyright © 2024 GitPulse",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "package.json"
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "GitPulse",
      "runAfterFinish": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    }
  }
}
